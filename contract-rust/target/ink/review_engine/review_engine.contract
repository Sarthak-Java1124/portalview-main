{"source":{"hash":"0x6c11bdf1c8da9b894036f6ca2526a7c150e119c3db327e8a4b16548df843a26f","language":"ink! 5.1.1","compiler":"rustc 1.95.0","wasm":"","build_info":{"build_mode":"Debug","cargo_contract_version":"5.0.3","rust_toolchain":"stable-x86_64-unknown-linux-gnu","wasm_opt_settings":{"keep_debug_symbols":false,"optimization_passes":"Z"}}},"contract":{"name":"review_engine","version":"1.0.0","authors":["PortalReview"]},"image":null,"spec":{"constructors":[{"args":[{"label":"escrow_address","type":{"displayName":["AccountId"],"type":0}},{"label":"reputation_address","type":{"displayName":["AccountId"],"type":0}}],"default":false,"docs":[],"label":"new","payable":false,"returnType":{"displayName":["ink_primitives","ConstructorResult"],"type":45},"selector":"0x9bae9d5e"}],"docs":[" ReviewEngine contract — coordinates review jobs, findings, consensus, and reward distribution.",""," Deployment flow:","   1. Deploy Escrow   → `escrow_address`","   2. Deploy Reputation → `reputation_address`","   3. Deploy ReviewEngine(escrow_address, reputation_address)","   4. Call Escrow::set_admin(review_engine_address)","   5. Call Reputation::set_admin(review_engine_address)",""," Job lifecycle:","   1. Submitter calls `register_job(job_id, description, contract_hash)` with POT attached.","      The stake is held in this contract as the reward pool.","   2. Qualified reviewers call `submit_finding(...)` with a POT bond attached.","   3. Once `CONSENSUS_THRESHOLD` findings are submitted, consensus is marked reached.","   4. Reviewers call `claim_reward(job_id)` to collect their share of the reward pool.","   5. Admin can call `slash_reviewer(job_id, reviewer)` to forfeit a bad reviewer's bond."],"environment":{"accountId":{"displayName":["AccountId"],"type":0},"balance":{"displayName":["Balance"],"type":10},"blockNumber":{"displayName":["BlockNumber"],"type":3},"chainExtension":{"displayName":["ChainExtension"],"type":60},"hash":{"displayName":["Hash"],"type":58},"maxEventTopics":4,"staticBufferSize":16384,"timestamp":{"displayName":["Timestamp"],"type":59}},"events":[{"args":[{"docs":[],"indexed":true,"label":"job_id","type":{"displayName":["String"],"type":4}},{"docs":[],"indexed":false,"label":"submitter","type":{"displayName":["AccountId"],"type":0}},{"docs":[],"indexed":false,"label":"stake_amount","type":{"displayName":["Balance"],"type":10}}],"docs":[],"label":"JobRegistered","module_path":"review_engine::review_engine","signature_topic":"0xfe17ff4379bcea895af36d594e2b6e38aeaf90ca97e56185015260939f4f7da7"},{"args":[{"docs":[],"indexed":true,"label":"job_id","type":{"displayName":["String"],"type":4}},{"docs":[],"indexed":true,"label":"reviewer","type":{"displayName":["AccountId"],"type":0}},{"docs":[],"indexed":false,"label":"amount","type":{"displayName":["Balance"],"type":10}}],"docs":[],"label":"RewardClaimed","module_path":"review_engine::review_engine","signature_topic":"0xa02f21c2b3acfbfa2a4c82c07c5c7f51bd124069889d0d4d0ed6927de7bc6ab1"},{"args":[{"docs":[],"indexed":true,"label":"job_id","type":{"displayName":["String"],"type":4}},{"docs":[],"indexed":true,"label":"reviewer","type":{"displayName":["AccountId"],"type":0}},{"docs":[],"indexed":false,"label":"bond_forfeited","type":{"displayName":["Balance"],"type":10}}],"docs":[],"label":"ReviewerSlashed","module_path":"review_engine::review_engine","signature_topic":"0xe3b548a143fbb5226c17c2e427f29c8de569619963debc725d52394fb1376c40"},{"args":[{"docs":[],"indexed":true,"label":"job_id","type":{"displayName":["String"],"type":4}}],"docs":[],"label":"ConsensusReached","module_path":"review_engine::review_engine","signature_topic":"0x193f83937ede9e4b24a05111faa0a60ceaefa3f7a89c62042401fac32a61b42c"},{"args":[{"docs":[],"indexed":true,"label":"finding_id","type":{"displayName":["String"],"type":4}},{"docs":[],"indexed":true,"label":"job_id","type":{"displayName":["String"],"type":4}},{"docs":[],"indexed":true,"label":"reviewer","type":{"displayName":["AccountId"],"type":0}}],"docs":[],