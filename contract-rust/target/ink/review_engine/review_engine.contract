":"job_id","type":{"displayName":["String"],"type":4}},{"label":"reviewer","type":{"displayName":["AccountId"],"type":0}}],"default":false,"docs":[" Slash a reviewer for submitting a bad / malicious finding."," Forfeits the reviewer's bond (transferred to admin) and bars them from claiming rewards."," Only callable by admin."],"label":"slash_reviewer","mutates":true,"payable":false,"returnType":{"displayName":["ink","MessageResult"],"type":47},"selector":"0x28c6d31a"},{"args":[{"label":"job_id","type":{"displayName":["String"],"type":4}}],"default":false,"docs":[" Mark a job as Finalized after all rewards have been distributed."," Only callable by admin."],"label":"finalize_job","mutates":true,"payable":false,"returnType":{"displayName":["ink","MessageResult"],"type":47},"selector":"0xb7f852a7"},{"args":[{"label":"new_admin","type":{"displayName":["AccountId"],"type":0}}],"default":false,"docs":[" Transfer admin rights to a new address."],"label":"set_admin","mutates":true,"payable":false,"returnType":{"displayName":["ink","MessageResult"],"type":47},"selector":"0x798dcad5"},{"args":[{"label":"job_id","type":{"displayName":["String"],"type":4}}],"default":false,"docs":[" Consensus state for a job, or `None` if the job is unknown."],"label":"get_consensus","mutates":false,"payable":false,"returnType":{"displayName":["ink","MessageResult"],"type":49},"selector":"0xa8113377"},{"args":[{"label":"offset","type":{"displayName":["u32"],"type":3}},{"label":"limit","type":{"displayName":["u32"],"type":3}}],"default":false,"docs":[" Paginated list of all registered jobs (ordered by registration time)."],"label":"get_jobs","mutates":false,"payable":false,"returnType":{"displayName":["ink","MessageResult"],"type":51},"selector":"0x13d3c67d"},{"args":[{"label":"job_id","type":{"displayName":["String"],"type":4}}],"default":false,"docs":[" All findings submitted for a given job."],"label":"get_findings","mutates":false,"payable":false,"returnType":{"displayName":["ink","MessageRe